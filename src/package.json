{
  "name": "nanopods-house",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "predev": "node scripts/build-products.mjs && node scripts/build-partials.mjs",
    "prebuild": "node scripts/build-products.mjs && node scripts/build-partials.mjs",
    "build:partials": "node scripts/build-partials.mjs",
    "build:products": "node scripts/build-products.mjs",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "test:visual:report": "playwright show-report"
  },
  "dependencies": {
    "lucide-react": "^0.469.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "globals": "^17.6.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
